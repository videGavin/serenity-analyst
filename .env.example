# Copy to .env and fill in your own X API credentials. NEVER commit the real .env.
# Get these from https://developer.x.com (full-archive search needs Pro/Enterprise tier).
X_CONSUMER_KEY=your_consumer_key_here
X_CONSUMER_SECRET=your_consumer_secret_here

# Optional: if you already have an app-only bearer token, set it directly instead.
# X_BEARER_TOKEN=your_bearer_token_here
